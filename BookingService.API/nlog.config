<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Warn"
      internalLogFile="logs/nlog-internal.log">

  <extensions>
    <add assembly="NLog.Web.AspNetCore"/>
  </extensions>

  <targets>
    <!-- Structured console output -->
    <target xsi:type="Console" name="console"
            layout="${longdate} | ${level:uppercase=true:padding=-5} | [ReqId: ${aspnet-TraceIdentifier}] [UserId: ${aspnet-request-headers:HeaderNames=X-User-Id:ValuesOnly=true}] | ${logger:shortName=true} | ${message} ${exception:format=tostring}" />

    <!-- Rolling file — new file each day, keep 30 days -->
    <target xsi:type="File" name="file"
            fileName="logs/booking-${shortdate}.log"
            archiveFileName="logs/archive/booking-{#}.log"
            archiveEvery="Day"
            archiveNumbering="Date"
            maxArchiveFiles="30"
            layout="${longdate} | ${level:uppercase=true:padding=-5} | [ReqId: ${aspnet-TraceIdentifier}] [UserId: ${aspnet-request-headers:HeaderNames=X-User-Id:ValuesOnly=true}] | ${logger:shortName=true} | ${aspnet-request-method} ${aspnet-request-url} | ${message} ${exception:format=tostring}" />

    <!-- Errors-only file for quick triage -->
    <target xsi:type="File" name="errors"
            fileName="logs/booking-errors-${shortdate}.log"
            layout="${longdate} | ${level:uppercase=true:padding=-5} | [ReqId: ${aspnet-TraceIdentifier}] [UserId: ${aspnet-request-headers:HeaderNames=X-User-Id:ValuesOnly=true}] | ${logger:shortName=true} | ${message} ${exception:format=tostring:maxInnerExceptionLevel=5}" />
  </targets>

  <rules>
    <!-- Skip noisy Microsoft/EF Core framework logs at Info level -->
    <logger name="Microsoft.*" maxlevel="Info" final="true" />
    <logger name="System.Net.Http.*" maxlevel="Info" final="true" />

    <!-- All app logs → console + file -->
    <logger name="*" minlevel="Debug" writeTo="console,file" />

    <!-- Errors and above → errors file too -->
    <logger name="*" minlevel="Error" writeTo="errors" />
  </rules>
</nlog>
